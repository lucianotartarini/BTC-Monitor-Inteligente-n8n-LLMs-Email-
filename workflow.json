      "parameters": {
        "jsCode": "// Gemini puede devolver \"content.parts\" o \"candidates[0].content.parts\"\nconst raw =\n  $json?.content?.parts?.[0]?.text ??\n  $json?.candidates?.[0]?.content?.parts?.[0]?.text ??\n  $json?.text ??\n  null;\n\nif (!raw) {\n  const keys = Object.keys($json || {});\n  throw new Error(`LLM2: no se encontró texto. Keys: ${keys.join(', ')}`);\n}\n\nconst s = String(raw).trim();\n\n// Extraer JSON { ... }\nconst match = s.match(/\\{[\\s\\S]*\\}/);\nif (!match) throw new Error(`LLM2: no devolvió JSON completo. Raw: ${s.slice(0, 200)}`);\n\nconst jsonStr = match[0];\n\nlet obj;\ntry {\n  obj = JSON.parse(jsonStr);\n} catch (e) {\n  throw new Error(`LLM2: JSON inválido: ${jsonStr}`);\n}\n\nreturn [{\n  json: {\n    summary: obj.summary ?? \"\",\n    context_24h: obj.context_24h ?? \"\",\n    risk_flags: Array.isArray(obj.risk_flags) ? obj.risk_flags : [],\n    scenario_next_1h: obj.scenario_next_1h ?? \"\",\n    suggested_action: obj.suggested_action ?? \"\",\n    llm2_raw: s\n  }\n}];"
      },
