      "parameters": {
        "jsCode": "// Extraer el texto JSON desde la respuesta de Gemini\nconst raw = $json?.content?.parts?.[0]?.text;\n\nif (!raw) {\n  throw new Error('LLM1: no se encontró content.parts[0].text');\n}\n\nlet obj;\ntry {\n  obj = JSON.parse(raw);\n} catch (e) {\n  throw new Error(`LLM1: JSON inválido: ${raw}`);\n}\n\n// Validación mínima (robustez)\nconst allowedStatus = new Set(['ALERTA', 'NORMAL']);\nconst allowedDirection = new Set(['UP', 'DOWN', 'FLAT']);\n\nif (!allowedStatus.has(obj.status) || !allowedDirection.has(obj.direction)) {\n  throw new Error(`LLM1: valores inesperados: ${JSON.stringify(obj)}`);\n}\n\n// Devolvemos campos listos para el IF\nreturn [{\n  json: {\n    status: obj.status,\n    direction: obj.direction,\n    llm_raw: raw\n  }\n}];"
      },
